# ---- LLM provider (OpenAI-compatible) ----
# Default provider is Groq (free + fast). Get a key at https://console.groq.com/keys
LLM_API_KEY=gsk-your-groq-key-here

# OpenAI-compatible base URL. Defaults to Groq if omitted.
#   Groq:       https://api.groq.com/openai/v1
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai/
#   OpenRouter: https://openrouter.ai/api/v1
#   OpenAI:     https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Model id for the chosen provider. Defaults to llama-3.3-70b-versatile (Groq).
#   Gemini example:     gemini-2.0-flash
#   OpenRouter example: meta-llama/llama-3.3-70b-instruct:free
#   OpenAI example:     gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile

# Optional GitHub personal access token to raise the public API rate limit (60/hr -> 5000/hr)
GITHUB_TOKEN=

# Port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:3000
